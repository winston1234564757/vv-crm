# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.nyc_output/
test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.tmp
*.temp
*.cache
*.swp

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (should never be committed)
.env
.env.local
.env.production
.env.development
.env.test
.env.example

# vercel
.vercel
.idea/
.vscode/
*.iml
.project

# backup files
*.bak
*_old.*
*_backup.*
*_copy.*

# personal junk
TODO.txt
NOTES.txt
scratch.*
test123.*

# debug logs
*.log

.env*
